{
    "label" : "lock",
    "action" : "$HOME/.config/hypr/scripts/LockScreen.sh",
    "text" : "Blocca schermo",
    "keybind" : "l"
}
{
    "label" : "reboot",
    "action" : "systemctl reboot",
    "text" : "Riavvia",
    "keybind" : "r"
}
{
    "label" : "shutdown",
    "action" : "systemctl poweroff",
    "text" : "Spegni",
    "keybind" : "s"
}
{
    "label" : "logout",
    "action" : "hyprctl dispatch exit 0",
    "text" : "Esci",
    "keybind" : "e"
}
{
    "label" : "suspend",
    "action" : "systemctl suspend",
    "text" : "Sospendi",
    "keybind" : "u"
}
{
    "label" : "hibernate",
    "action" : "systemctl hibernate",
    "text" : "Iberna",
    "keybind" : "h"
}
